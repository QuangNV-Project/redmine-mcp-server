# Redmine Configuration
REDMINE_URL=https://your-redmine.com
REDMINE_USERNAME=your_username
REDMINE_PASSWORD=your_password

# Transport: "stdio" (default, for Cursor local) or "sse" (HTTP server with port)
TRANSPORT=stdio

# Port for SSE transport (only used when TRANSPORT=sse)
PORT=3000

# Security (SSE mode only)
MCP_AUTH_TOKEN=your-secret-token-here
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# MongoDB (optional - enables multi-repo project management)
MONGODB_URI=mongodb://mcp_user:STRONG_PASSWORD@localhost:10009/mcp-server

# Git Configuration (fallback when no MongoDB project is matched)
GIT_REPO_PATH=/path/to/your/local/repo

# Branch naming convention: ticket-id | ticket-id-title
BRANCH_FORMAT=ticket-id
